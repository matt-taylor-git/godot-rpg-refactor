[gd_scene load_steps=5 format=3 uid="uid://town_scene"]

[ext_resource type="Theme" uid="uid://b7w5k8j6x2q1a" path="res://resources/ui_theme.tres" id="1"]
[ext_resource type="Script" path="res://scripts/ui/TownScene.gd" id="2"]
[ext_resource type="PackedScene" uid="uid://banlt66gdvndq" path="res://scenes/components/ui_button.tscn" id="3"]
[ext_resource type="Shader" path="res://assets/main_menu_bg.gdshader" id="4"]
[ext_resource type="Texture2D" path="res://assets/divider.png" id="5"]

[sub_resource type="ShaderMaterial" id="ShaderMaterial_bg"]
shader = ExtResource("4")
shader_parameter/time_scale = 0.45
shader_parameter/wave_intensity = 0.25
shader_parameter/color_primary = Color(0.07, 0.055, 0.04, 1)
shader_parameter/color_accent = Color(0.16, 0.10, 0.05, 1)
shader_parameter/reduce_motion = false
shader_parameter/grain_intensity = 0.03
shader_parameter/ember_intensity = 0.07
shader_parameter/ember_color = Color(0.95, 0.5, 0.15, 1)

[node name="TownScene" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("1")
script = ExtResource("2")

[node name="Background" type="Panel" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
material = SubResource("ShaderMaterial_bg")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 16
alignment = 1

[node name="Title" type="Label" parent="VBoxContainer"]
layout_mode = 2
text = "Welcome to Town"
horizontal_alignment = 1
theme_type_variation = "H1"

[node name="Divider" type="TextureRect" parent="VBoxContainer"]
custom_minimum_size = Vector2(0, 72)
layout_mode = 2
size_flags_horizontal = 3
mouse_filter = 2
texture = ExtResource("5")
expand_mode = 1
stretch_mode = 5

[node name="Subtitle" type="Label" parent="VBoxContainer"]
layout_mode = 2
text = "Rest, resupply, and take on work before the road calls."
horizontal_alignment = 1
autowrap_mode = 3

[node name="CardsRow" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 16
alignment = 1

[node name="ShopCard" type="PanelContainer" parent="VBoxContainer/CardsRow"]
layout_mode = 2
size_flags_horizontal = 3
custom_minimum_size = Vector2(200, 180)
theme_type_variation = "Panel"

[node name="VBox" type="VBoxContainer" parent="VBoxContainer/CardsRow/ShopCard"]
layout_mode = 2
theme_override_constants/separation = 10
alignment = 1

[node name="CardTitle" type="Label" parent="VBoxContainer/CardsRow/ShopCard/VBox"]
layout_mode = 2
text = "Market"
horizontal_alignment = 1
theme_type_variation = "H2"

[node name="Subtitle" type="Label" parent="VBoxContainer/CardsRow/ShopCard/VBox"]
layout_mode = 2
text = "Buy potions and gear for the journey."
horizontal_alignment = 1
autowrap_mode = 3

[node name="ShopButton" parent="VBoxContainer/CardsRow/ShopCard/VBox" instance=ExtResource("3")]
layout_mode = 2
text = "Open Shop"

[node name="QuestCard" type="PanelContainer" parent="VBoxContainer/CardsRow"]
layout_mode = 2
size_flags_horizontal = 3
custom_minimum_size = Vector2(200, 180)
theme_type_variation = "Panel"

[node name="VBox" type="VBoxContainer" parent="VBoxContainer/CardsRow/QuestCard"]
layout_mode = 2
theme_override_constants/separation = 10
alignment = 1

[node name="CardTitle" type="Label" parent="VBoxContainer/CardsRow/QuestCard/VBox"]
layout_mode = 2
text = "Quest Board"
horizontal_alignment = 1
theme_type_variation = "H2"

[node name="Subtitle" type="Label" parent="VBoxContainer/CardsRow/QuestCard/VBox"]
layout_mode = 2
text = "Speak with the town quest giver."
